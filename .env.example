# ── Google / Gmail OAuth (contact form email delivery) ───────────────
# Copy this file to .env.local and fill in real values.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Redirect URI — must match EXACTLY what you register in Google Cloud Console.
# Local:      http://localhost:3000/api/oauth/google/callback
# Production: https://your-domain.com/api/oauth/google/callback
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/oauth/google/callback

# The Gmail account that sends the mail (must be the account you authorize).
GMAIL_USER=

# Where contact-form submissions are delivered.
CONTACT_TO=

# Obtained from the one-time OAuth flow at /api/oauth/google
GOOGLE_REFRESH_TOKEN=
