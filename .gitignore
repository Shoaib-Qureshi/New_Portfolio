# Dependencies
node_modules/
pnpm-lock.yaml

# Next.js
.next/
out/

# Production/build output
dist/
build/

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Environment variables
.env
.env.*
!.env.example

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Local database/runtime files (DB is seeded from lib/seed-content.ts on first run;
# never commit it — it holds runtime content + contact submissions)
/data/*.sqlite
*.sqlite-wal
*.sqlite-shm

# User-uploaded media (runtime, written by the admin panel)
/data/uploads/

# Email preview artifacts
email-preview-*.html

# Throwaway scripts / local screenshots
tmp-*.cjs
tmp-*.js
tmp-*.png
pw-*.png

# Test and coverage output
coverage/
test-results/
playwright-report/

# Local screenshots and visual-check artifacts
bugfix-*.png
mobile-*.png
visual-*.png
creative-*.png
debug-*.png

# OS/editor files
.DS_Store
Thumbs.db
.vscode/
.idea/
